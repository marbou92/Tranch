[input_devices]

pointing/emulate_touch_from_mouse=true

[layer_names]

3d_physics/layer_1="player"
3d_physics/layer_2="environment"
3d_physics/layer_3="enemies"
3d_physics/layer_4="interactables"
3d_physics/layer_5="noise"
3d_physics/layer_6="zone_triggers"

[rendering]

renderer/rendering_method="forward_plus"
renderer/rendering_method.mobile="mobile"
textures/vram_compression/import_etc2_astc=true
textures/vram_compression/import_etc2=true
anti_aliasing/quality/msaa_3d=2
anti_aliasing/quality/screen_space_aa=0
environment/defaults/default_clear_color=Color(0.02, 0.02, 0.04, 1)

[internationalization]

locale/translations=PackedStringArray("res://localization/en.csv")
locale/test=false
