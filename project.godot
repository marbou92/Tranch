; Engine configuration file.
; It's best edited using the Godot editor, but can also be edited
; manually. This file contains all project settings.

[application]

config/name="Tranch"
config/description="Open-World First-Person Horror - Don't run. He hears everything."
config/version="0.1.0"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoloads/event_bus.gd"
GameState="*res://autoloads/game_state.gd"
SanitySystem="*res://autoloads/sanity_system.gd"
GraphicsTierManager="*res://autoloads/graphics_tier_manager.gd"
SaveManager="*res://autoloads/save_manager.gd"
AudioBusManager="*res://autoloads/audio_bus_manager.gd"
InventorySystem="*res://inventory/inventory_system.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/vsync/vsync_mode=1

